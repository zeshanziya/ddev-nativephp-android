#!/bin/bash

## Description: Generate Android signing credentials (keystore) inside the android-builder container
## Usage: native-android-credentials
## Example: ddev native-android-credentials

CONTAINER=$(docker ps --filter "name=ddev-${DDEV_SITENAME}-android-builder" --filter "status=running" --format "{{.Names}}" | head -1)

if [ -z "$CONTAINER" ]; then
  echo "android-builder container is not running. Run 'ddev restart' first."
  exit 1
fi

echo "Generating Android credentials in ${CONTAINER}..."
echo ""

docker exec -it "$CONTAINER" \
  php /var/www/html/artisan native:credentials android
