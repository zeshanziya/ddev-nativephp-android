#!/bin/bash

## Description: Build Android APK/AAB inside the android-builder container (no host tools required)
## Usage: native-android-build [--release|--bundle]
## Example: ddev native-android-build
## Example: ddev native-android-build --release
## Example: ddev native-android-build --bundle

BUILD_TYPE="release"

for arg in "$@"; do
  case $arg in
    --bundle) BUILD_TYPE="bundle" ;;
    --release) BUILD_TYPE="release" ;;
  esac
done

CONTAINER="ddev-${DDEV_SITENAME}-android-builder"

if ! docker inspect "${CONTAINER}" > /dev/null 2>&1; then
  echo "android-builder container not found. Run 'ddev restart' first."
  exit 1
fi

echo "Building Android (${BUILD_TYPE}) in ${CONTAINER}..."
echo ""

docker exec -i "${CONTAINER}" \
  php /var/www/html/artisan native:run \
  --target=android \
  "--${BUILD_TYPE}" \
  --no-tty
