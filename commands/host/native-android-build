#!/bin/bash

## Description: Build a signed Android APK/AAB inside the android-builder container (no host tools required)
## Usage: native-android-build [--release|--bundle]
## Example: ddev native-android-build
## Example: ddev native-android-build --release
## Example: ddev native-android-build --bundle

BUILD_TYPE="release"

for arg in "$@"; do
  case $arg in
    --bundle) BUILD_TYPE="bundle" ;;
    --release) BUILD_TYPE="release" ;;
  esac
done

CONTAINER=$(docker ps --filter "name=ddev-${DDEV_SITENAME}-android-builder" --filter "status=running" --format "{{.Names}}" | head -1)

if [ -z "$CONTAINER" ]; then
  echo "android-builder container is not running. Run 'ddev restart' first."
  exit 1
fi

echo "Building signed Android (${BUILD_TYPE}) in ${CONTAINER}..."
echo ""

docker exec -i "$CONTAINER" \
  php /var/www/html/artisan native:package \
  --android \
  "--build-type=${BUILD_TYPE}" \
  --no-tty
